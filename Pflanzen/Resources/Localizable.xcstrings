    "notification.birthday.message" : {
      "comment" : "Push notification body for plant birthday",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ wird heute %lld! gönn ihr/ihm was Besonderes 🎈"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "today %@ turns %lld! give them some extra love 🎈"
          }
        }
      }
    },
    "notification.birthday.title" : {
      "comment" : "Push notification title for plant birthday",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "alles Gute zum Geburtstag 🎂"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "happy birthday 🎂"
          }
        }
      }
    },
    "notification.fertilize.hint" : {
      "comment" : "Appended to notification when fertilizing is due",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "und düngen wäre auch fällig! 🌿"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "also time to fertilize! 🌿"
          }
        }
      }
    },
    "notification.message.day0" : {
      "comment" : "Notification body: due today",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "hey, hier ist %@. ich hab Durst. gieß mich heute noch, bitte."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "yo %@ here. thirst levels critical. hydration required."
          }
        }
      }
    },
    "notification.message.day1" : {
      "comment" : "Notification body: 1 day overdue",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ist %@ ein Witz für dich? die Erde ist schon knochentrocken."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "is %@ a joke to you? soil is literally dust rn."
          }
        }
      }
    },
    "notification.message.day2" : {
      "comment" : "Notification body: 2 days overdue",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ich schmeiß Blätter als wär's Herbst. %@ braucht jetzt sofort Wasser."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "dropping leaves like its my job. %@ needs liquid asap."
          }
        }
      }
    },
    "notification.message.day3" : {
      "comment" : "Notification body: 3 days overdue",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "halloooo?? %@ hier, meld mich aus dem Jenseits. Wasser wäre jetzt das Schönste."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "hello?? %@ checking in from the abyss. water would slap rn."
          }
        }
      }
    },
    "notification.message.day4" : {
      "comment" : "Notification body: 4 days overdue",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "von meinem Besitzer komplett geghostet. herzlichen Glückwunsch, %@. 🤡"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "completely ghosted by my creator. love that for %@. 🤡"
          }
        }
      }
    },
    "notification.message.day5" : {
      "comment" : "Notification body: 5 days overdue",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "schau dir %@ an und sag mir ich seh zufrieden aus. gieß mich. ich flehe dich an."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "look at %@ and tell me i look happy. give me the juice. i'm begging."
          }
        }
      }
    },
    "notification.message.day6" : {
      "comment" : "Notification body: 6 days overdue",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "wenn du willst, dass %@ stirbt, sag's einfach. gieß mich, digga."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "if you want %@ dead just say that. hydrate me bro."
          }
        }
      }
    },
    "notification.message.day7" : {
      "comment" : "Notification body: 7 days overdue",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "hilfe! %@ macht gerade einen Speedrun im Verdursten! 🏜 kein Spaß."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "help! %@ is speedrunning dehydration! 🏜 not a drill."
          }
        }
      }
    },
    "notification.message.day8" : {
      "comment" : "Notification body: 8 days overdue",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SOS. Erde trocken. Wurzeln verdorrt. rette %@, bevor es zu spät ist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SOS. soil dry. roots crispy. save %@ before i rage quit life."
          }
        }
      }
    },
    "notification.message.day9" : {
      "comment" : "Notification body: 9 days overdue",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ich schreib gerade mein Testament. rip %@."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "writing my will rn. rip %@."
          }
        }
      }
    },
    "notification.message.day10" : {
      "comment" : "Notification body: 10+ days overdue",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "offiziell schlechtste Pflanzenperson ever. ich vergehe. rip %@. 💀"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "officially the worst plant parent. fading into the void. rip %@. 💀"
          }
        }
      }
    },
